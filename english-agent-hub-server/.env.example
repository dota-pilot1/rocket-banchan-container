JWT_SECRET=english-agent-hub-dev-secret-key-must-be-at-least-32-bytes-long

# Encrypt user-provided API keys before storing them.
# Use a long random value in real environments.
CREDENTIAL_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# OpenAI Realtime API defaults. Individual users will provide their own API key.
OPENAI_REALTIME_BASE_URL=https://api.openai.com/v1/realtime
OPENAI_REALTIME_DEFAULT_MODEL=gpt-realtime-2

# Kakao notification integration placeholders.
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:4301/api/kakao/oauth/callback

AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=ap-northeast-2
AWS_S3_PREFIX=english-agent-hub
