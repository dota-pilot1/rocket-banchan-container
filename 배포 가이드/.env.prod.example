# EnglishAgentHub production env example
# 위치: /home/ubuntu/english-agent-hub/.env  (퍼미션 600)

# ---- Required ----
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
API_KEY_SECRET=change-this-to-a-long-random-secret-32-bytes-or-more
# ⚠️ API_KEY_SECRET은 한 번 정하면 변경 금지 (저장된 사용자 OpenAI 키 복호화 불가)

OPENAI_API_KEY=sk-proj-system-fallback-key
# 시스템 폴백용. 사용자가 개인 키를 등록하면 그 키가 우선 사용된다.

# ---- CORS ----
ALLOWED_ORIGIN=https://dxline-tallent.com

# ---- Port ----
# 로컬 기본값은 3301. 운영은 Nginx가 4301로 프록시하므로 반드시 4301로 고정.
SERVER_PORT=4301

# ---- OpenAI 모델 (선택) ----
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_TRANSLATION_MODEL=gpt-5-nano
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# ---- S3 업로드 (선택) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=beauty-book-hair-front
AWS_S3_REGION=ap-northeast-2
AWS_S3_PREFIX=english-agent-hub

# ---- DB (기본값 그대로 두면 됨) ----
# Spring application.yaml의 기본값:
#   url: jdbc:postgresql://localhost:5436/english_agent_hub
#   username: postgres
#   password: postgres
# 필요 시 SPRING_DATASOURCE_* 로 override 가능
